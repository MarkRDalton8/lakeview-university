# Piano API Configuration
# Get these values from Piano Dashboard

# API Token - Get from: Piano Dashboard → Settings → API
PIANO_API_TOKEN=your_api_token_here

# Application ID (AID) - Find in: Piano Dashboard → Settings
PIANO_APP_ID=QiNgMM49pu

# Site License Contract ID
# Find in: Piano Dashboard → Products → Licenses → [Your License] → Contracts tab
# Click on your contract to see the contract_id in the URL or details
PIANO_CONTRACT_ID=your_contract_id_here

# API Base URL (usually don't need to change this)
# Use sandbox for testing: https://sandbox.tinypass.com/api/v3
# Use production: https://api.tinypass.com/api/v3
PIANO_API_BASE_URL=https://api.tinypass.com/api/v3

# CSV File Path
# Path to the CSV file containing users to upload
CSV_FILE_PATH=users_to_upload.csv

# Rate Limiting
# Delay in seconds between API requests (0.1 = 10 requests/sec)
# Increase this if you hit rate limits (e.g., 0.2 = 5 requests/sec)
RATE_LIMIT_DELAY=0.1
