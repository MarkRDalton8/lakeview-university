{
  "info": {
    "name": "Piano Site Licensing API",
    "description": "Collection for managing users and site licenses in Piano VX API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "api_base_url",
      "value": "https://api.tinypass.com/api/v3",
      "type": "string"
    },
    {
      "key": "api_token",
      "value": "YOUR_API_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "app_id",
      "value": "QiNgMM49pu",
      "type": "string"
    },
    {
      "key": "contract_id",
      "value": "YOUR_CONTRACT_ID_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Create User",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "api_token",
              "value": "{{api_token}}",
              "type": "text"
            },
            {
              "key": "aid",
              "value": "{{app_id}}",
              "type": "text"
            },
            {
              "key": "email",
              "value": "sarah.johnson@university.edu",
              "type": "text"
            },
            {
              "key": "first_name",
              "value": "Sarah",
              "type": "text"
            },
            {
              "key": "last_name",
              "value": "Johnson",
              "type": "text"
            },
            {
              "key": "uid",
              "value": "USR001",
              "type": "text"
            },
            {
              "key": "custom_field_newsletter_opt_in",
              "value": "true",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/user/create",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "user",
            "create"
          ]
        },
        "description": "Creates or updates a user in Piano. If the email already exists, the user will be updated."
      },
      "response": []
    },
    {
      "name": "2. Add User to Site License Contract",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "api_token",
              "value": "{{api_token}}",
              "type": "text"
            },
            {
              "key": "aid",
              "value": "{{app_id}}",
              "type": "text"
            },
            {
              "key": "contract_id",
              "value": "{{contract_id}}",
              "type": "text"
            },
            {
              "key": "email",
              "value": "sarah.johnson@university.edu",
              "type": "text"
            },
            {
              "key": "first_name",
              "value": "Sarah",
              "type": "text"
            },
            {
              "key": "last_name",
              "value": "Johnson",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/licensing/contractUser/create",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "licensing",
            "contractUser",
            "create"
          ]
        },
        "description": "Adds a user to a site license contract. This creates the user in the contract."
      },
      "response": []
    },
    {
      "name": "3. Send Invitation Email",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "api_token",
              "value": "{{api_token}}",
              "type": "text"
            },
            {
              "key": "aid",
              "value": "{{app_id}}",
              "type": "text"
            },
            {
              "key": "contract_id",
              "value": "{{contract_id}}",
              "type": "text"
            },
            {
              "key": "contract_user_id",
              "value": "CUMG693V0I2V",
              "type": "text",
              "description": "Get this from the response of step 2 (contract_user.contract_user_id)"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/licensing/contractUser/invite",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "licensing",
            "contractUser",
            "invite"
          ]
        },
        "description": "Sends invitation email to a contract user. The email contains a link to the redemption landing page."
      },
      "response": []
    },
    {
      "name": "4. List Contract Users",
      "request": {
        "method": "POST",
        "header": [],
