              "key": "api_token",
              "value": "{{api_token}}",
              "type": "text"
            },
            {
              "key": "aid",
              "value": "{{app_id}}",
              "type": "text"
            },
            {
              "key": "contract_id",
              "value": "{{contract_id}}",
              "type": "text"
            },
            {
              "key": "limit",
              "value": "100",
              "type": "text",
              "description": "Number of results per page (default: 100)"
            },
            {
              "key": "offset",
              "value": "0",
              "type": "text",
              "description": "Pagination offset (default: 0)"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/licensing/contractUser/list",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "licensing",
            "contractUser",
            "list"
          ]
        },
        "description": "Lists all users in a site license contract. Returns contract_user_id needed for other operations."
      },
      "response": []
    },
    {
      "name": "5. Redeem Contract Access for User",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "api_token",
              "value": "{{api_token}}",
