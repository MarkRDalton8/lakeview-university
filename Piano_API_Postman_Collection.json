            {
              "key": "email",
              "value": "sarah.johnson@university.edu",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/licensing/contract/redeem",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "licensing",
            "contract",
            "redeem"
          ]
        },
        "description": "Redeems access through the contract for a specific user. Must be called after adding user to contract."
      },
      "response": []
    },
    {
      "name": "6. Get User by Email",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "api_token",
              "value": "{{api_token}}",
              "type": "text"
            },
            {
              "key": "aid",
              "value": "{{app_id}}",
              "type": "text"
            },
            {
              "key": "email",
              "value": "sarah.johnson@university.edu",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/user/get",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "user",
            "get"
          ]
        },
        "description": "Retrieves user details by email address."
      },
      "response": []
    },
    {
      "name": "7. List User Access",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "api_token",
              "value": "{{api_token}}",
              "type": "text"
            },
            {
              "key": "aid",
              "value": "{{app_id}}",
              "type": "text"
            },
            {
              "key": "user_uid",
              "value": "USR001",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/user/access/list",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "user",
            "access",
            "list"
          ]
        },
        "description": "Lists all active access grants (terms) for a user."
      },
      "response": []
    },
    {
      "name": "8. Remove User from Contract",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "api_token",
              "value": "{{api_token}}",
              "type": "text"
            },
            {
              "key": "aid",
              "value": "{{app_id}}",
              "type": "text"
            },
            {
              "key": "contract_id",
              "value": "{{contract_id}}",
              "type": "text"
            },
            {
              "key": "contract_user_id",
              "value": "CUMG693V0I2V",
              "type": "text",
              "description": "Get this from the list endpoint (contract_user_id field)"
            }
          ]
        },
        "url": {
          "raw": "{{api_base_url}}/publisher/licensing/contractUser/removeAndRevoke",
          "host": [
            "{{api_base_url}}"
          ],
          "path": [
            "publisher",
            "licensing",
            "contractUser",
            "removeAndRevoke"
          ]
        },
        "description": "Removes and revokes a user from a site license contract. Works for both PENDING and ACTIVE users. Useful for demo cleanup."
